{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/doctor/:path*", "destination": "/details" },
    { "source": "/service/:path*", "destination": "/details" },
    { "source": "/product/:path*", "destination": "/details" },
    { "source": "/exercise/:path*", "destination": "/details" },
    { "source": "/exercises/group/:path*", "destination": "/exercises" },
    { "source": "/exercises/dashboard", "destination": "/exercises" },
    { "source": "/exercises/login", "destination": "/exercises" },
    { "source": "/exercises/:path*", "destination": "/exercises" },
    { "source": "/admin", "destination": "/admin" },
    { "source": "/services", "destination": "/services" },
    { "source": "/doctors", "destination": "/doctors" },
    { "source": "/products", "destination": "/products" },
    { "source": "/articles", "destination": "/articles" },
    { "source": "/exercises", "destination": "/exercises" },
    { "source": "/prescription", "destination": "/prescription" },
    { "source": "/:slug([^/.]+)", "destination": "/details" }
  ]
}
