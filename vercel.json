{
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/doctor/:path*", "destination": "/details.html" },
    { "source": "/service/:path*", "destination": "/details.html" },
    { "source": "/product/:path*", "destination": "/details.html" },
    { "source": "/exercise/:path*", "destination": "/details.html" },
    { "source": "/exercises/group/:path*", "destination": "/exercises.html" },
    { "source": "/exercises/dashboard", "destination": "/exercises.html" },
    { "source": "/exercises/login", "destination": "/exercises.html" },
    { "source": "/exercises/:path*", "destination": "/exercises.html" },
    { "source": "/exercises", "destination": "/exercises.html" },
    { "source": "/prescription", "destination": "/prescription.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/services", "destination": "/services.html" },
    { "source": "/doctors", "destination": "/doctors.html" },
    { "source": "/products", "destination": "/products.html" },
    { "source": "/articles", "destination": "/articles.html" },
    { "source": "/:slug", "destination": "/details.html" }
  ]
}
